PORT=3000
# Comma-separated. Use your deployed Vercel URL in production, for example:
# CORS_ORIGIN=https://yt-download2406.vercel.app
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=25
MAX_VIDEO_DURATION_SECONDS=14400
# Run cleanup every 30 minutes instead of 1 hour (in milliseconds)
TEMP_CLEANUP_INTERVAL_MS=1800000

# Delete files older than 12 hours instead of 24 (in milliseconds)
TEMP_FILE_MAX_AGE_MS=43200000
# Optional: point to a pre-installed yt-dlp binary and skip auto-downloads
# YT_DLP_PATH=/usr/local/bin/yt-dlp
# Optional: path to a cookies file for YouTube authentication
# Get cookies using: https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
# YT_DLP_COOKIES_FILE=/path/to/cookies.txt
# Optional: extract cookies from browser automatically (firefox, chrome, etc.)
# YT_DLP_COOKIES_FROM_BROWSER=firefox
